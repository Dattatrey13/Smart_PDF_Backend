# ─── Email Provider ────────────────────────────────────────────────────
# Set EMAIL_PROVIDER to "resend" (recommended for Render/cloud) or "smtp"
EMAIL_PROVIDER=resend

# ─── Resend Configuration (recommended for cloud platforms) ────────────
# 1. Sign up at https://resend.com (free: 100 emails/day)
# 2. Add & verify your domain at https://resend.com/domains
# 3. Create an API key at https://resend.com/api-keys
RESEND_API_KEY="re_FPUA6mQC_9ixu7SEeVi2x2igdEXTPfBXf"
SMTP_FROM_NAME=Smart PDF
SMTP_FROM_EMAIL=otp@yourdomain.com

# ─── Gmail SMTP Configuration (fallback, blocked on Render free tier) ──
# To enable OTP email sending:
# 1. Use Gmail with App Password (not your regular password)
# 2. Enable 2-Factor Authentication on your Google Account
# 3. Generate App Password: https://myaccount.google.com/apppasswords
# 4. Use the 16-character app password (without spaces) as SMTP_PASSWORD

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=rudraailabs.dev@gmail.com
SMTP_PASSWORD=kcfj fvzu mmnw nuil

# ─── Alternative Providers ─────────────────────────────────────────────
# SendGrid: SMTP_HOST=smtp.sendgrid.net, port 587, username=apikey, password=<api-key>
# AWS SES: SMTP_HOST=email-smtp.<region>.amazonaws.com, port 587
# Mailgun: SMTP_HOST=smtp.mailgun.org, port 587

# ─── Firebase Configuration ────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json

# ─── API Configuration ────────────────────────────────────────────────
ENVIRONMENT=production
API_VERSION=2.0.0
